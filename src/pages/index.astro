---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';

import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'INIT — Club Website',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero: 팀 소개 및 팀 목적 -->
  <Hero
    actions={[
      { text: 'Learn more', href: '#features' },
      { text: 'Contact us', href: '#contact' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'INIT Hero Image' }}
  >
    <Fragment slot="title"> INIT </Fragment>

    <Fragment slot="subtitle">
      저희팀은 컴퓨터 공학 분야의 다양한 전공을 학습하는 커뮤니티입니다. 입문자들을 위한 기초 스터디 그룹부터 포트폴리오
      실적을 위한 소프트웨어 그룹, 정보보안 연구 그룹 등 다양한 활동을 지원하고 있습니다.
    </Fragment>
  </Hero>

  <!-- Features: 팀 목적 -->
  <Features
    id="features"
    tagline="Mission"
    title="팀 목적"
    subtitle="우리 팀이 추구하는 가치와 목표입니다."
    columns={1}
    items={[
      {
        title: '진로 탐색',
        description: '아직 프로그래밍을 잘 모르더라도 함께 공부하며 다른 그룹들과의 세미나를 통해 진로를 탐색합니다.',
        icon: 'tabler:target',
      },
      {
        title: '취업',
        description:
          '오픈소스 제작 및 배포, 취약점 발굴, 논문 작성, 대회 참가, 인턴 및 교육생 등등의 활동 지원을 통해 취업이나 연구직으로의 진출을 위한 포트폴리오를 제작합니다.',
        icon: 'tabler:briefcase',
      },
      {
        title: '목적 3',
        description: '설명을 작성하세요.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <!-- Features2: 세부 그룹 소개 -->
  <Features2
    id="groups"
    tagline="Groups"
    title="세부 그룹 소개"
    subtitle="팀 내부에 존재하는 세부 그룹들입니다."
    items={[
      {
        title: '기초 스터디 그룹',
        description:
          '초보자도 가입 가능한 입문 과정입니다. Python, C 학습을 주력으로 하며 기본 함수와 알고리즘을 배웁니다.',
        icon: 'tabler:book',
        callToAction: { text: '자세히 보기', href: '/groups/study' },
        callToAction2: { text: '팀원 소개', href: '/groups/study/members' },
      },
      {
        title: '소프트웨어 그룹',
        description: '인공지능 연구 · 게임 개발 · 일반 소프트웨어 개발의 세부 그룹으로 나뉘어 활동합니다.',
        icon: 'tabler:code',
        callToAction: { text: '자세히 보기', href: '/groups/software' },
        callToAction2: { text: '팀원 소개', href: '/groups/software/members' },
      },
      {
        title: '정보보안 연구 그룹',
        description: '정보보안 분야를 집중적으로 연구합니다.',
        icon: 'tabler:shield-lock',
        callToAction: { text: '자세히 보기', href: '/groups/security' },
        callToAction2: { text: '팀원 소개', href: '/groups/security/members' },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- 지도 교수 및 동아리 부장 -->
  <Features2
    id="members"
    tagline="Members"
    title="운영진"
    items={[
      {
        title: '지도 교수',
        description: '신용제 교수님 · 스마트IT학부',
        icon: 'tabler:school',
      },
      {
        title: '동아리 부장',
        description: '김동혁 · 스마트IT학부',
        icon: 'tabler:crown',
      },
    ]}
    columns={2}
  />

  <!-- Stats: 팀 실적 -->
  <Stats
    title="팀 실적"
    subtitle="우리 팀의 주요 성과입니다."
    stats={[
      { title: '프로젝트', amount: '2' },
      { title: '수상', amount: '3' },
      { title: '팀원', amount: '4' },
      { title: '논문', amount: '2' },
      { title: '취약점 발견', amount: '5' },
    ]}
  />

  <!-- FAQs -->
  <FAQs
    id="faq"
    title="자주 묻는 질문"
    subtitle="궁금한 점이 있으시면 아래를 확인해주세요."
    tagline="FAQ"
    columns={1}
    classes={{ container: 'max-w-4xl' }}
    items={[
      {
        title: '프로그래밍 언어를 잘 몰라도 활동 가능한가요?',
        description:
          '네. 기초 스터디 그룹은 Python, C언어와 같은 프로그래밍 언어를 기초부터 함께 공부하는 스터디 그룹입니다. 기초 스터디 그룹에서 프로그래밍 언어를 학습하며 다른 그룹들에서 진행되는 전문가 초청 강연 및 외부 팀 연합 세미나, 연구 세미나에도 참여하실 수 있습니다.',
      },
      {
        title: '질문 2',
        description: '답변을 작성하세요.',
      },
      {
        title: '질문 3',
        description: '답변을 작성하세요.',
      },
    ]}
  />

  <!-- Contact -->
  <div id="contact">
    <HeroText
      tagline="Contact"
      title="문의"
      subtitle="문의 사항이 있으시면 아래 이메일로 연락해주세요.<br/><br/><a href='mailto:init.devclub@gmail.com' class='text-primary font-semibold'>init.devclub@gmail.com</a>"
    />
  </div>
</Layout>
